!Output/.gitkeep

# ─── Raw TLE data (large files) ───────────────────────────────────────────────
data/raw/*.txt

# ─── Trained model artefacts ──────────────────────────────────────────────────
*.keras
*.pkl
*.h5
*.pt
*.pth
*.onnx
*.pb

# ─── Parquet / data files ─────────────────────────────────────────────────────
*.parquet
*.csv
!scripts/**/*.csv
*.json
!dashboard/package.json
!dashboard/tsconfig*.json
!dashboard/postcss.config.json

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ─── Node / React dashboard ───────────────────────────────────────────────────
dashboard/node_modules/
dashboard/dist/
dashboard/.env
dashboard/.env.local
dashboard/.env.*.local

# ─── Docker ───────────────────────────────────────────────────────────────────
.docker/

# ─── Coverage / testing ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.bak
*.tmp
tmp/
temp/
